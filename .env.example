# ============== Supabase (قاعدة البيانات) ==============
# مهم: لا تستخدم رابط المشروع (https://xxx.supabase.co)
# استخدم رابط PostgreSQL من: Project Settings → Database → Connection string → URI
# فعّل "Use connection pooling" (البورت 6543)
# مثال: postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=


# ============== Better Auth ==============
baseURL=http://localhost:3000
BETTER_AUTH_SECRET=


# ============== Google (تسجيل الدخول) ==============
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ============== Polar (نظام الكريدت) ==============
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_METER_NAME=
POLAR_SERVER=sandbox
POLAR_CREDITS_PER_ORDER=30
POLAR_CREDITS_PRODUCT_ID=
NEXT_PUBLIC_POLAR_CREDITS_PRODUCT_ID=


# ============== Cloudinary (رفع صور الوجبات) ==============
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name


# ============== Gemini (تحليل الوجبات بالذكاء الاصطناعي) ==============
GEMINI_API_KEY=
# أو استخدم GOOGLE_API_KEY إذا كان نفس مفتاح جوجل


# ============== اختياري: حد الطلبات (Rate limit) ==============
# RATE_LIMIT_ACTIONS_PER_MINUTE=30
# RATE_LIMIT_API_PER_MINUTE=60
